{
  "entities": {
    "MessageAnalysis": {
      "title": "MessageAnalysis",
      "description": "Individual message analysis result.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Username of the message author."
        },
        "extractedText": {
          "type": "string",
          "description": "The extracted text of the message."
        },
        "sentiment": {
          "type": "string",
          "enum": ["Olumlu", "Olumsuz", "Nötr"],
          "description": "Sentiment of the message."
        },
        "explanation": {
          "type": "string",
          "description": "Explanation for the sentiment."
        }
      },
      "required": ["extractedText", "sentiment", "explanation"]
    },
    "AnalysisResult": {
      "title": "AnalysisResult",
      "description": "The overall analysis result of a document.",
      "type": "object",
      "properties": {
        "platform": {
          "type": "string",
          "description": "The platform the document is from."
        },
        "subCategory": {
          "type": "string",
          "description": "The sub-category of the platform."
        },
        "fileName": {
          "type": "string",
          "description": "The name of the uploaded file."
        },
        "overallSentiment": {
          "type": "string",
          "enum": ["Olumlu", "Olumsuz", "Nötr", "Karışık"],
          "description": "The overall sentiment of the document."
        },
        "summary": {
          "type": "string",
          "description": "A summary of the analysis."
        },
        "messages": {
          "type": "array",
          "items": {
            "$ref": "#/entities/MessageAnalysis"
          },
          "description": "The individual message analyses."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The time the analysis was created."
        }
      },
      "required": ["platform", "fileName", "overallSentiment", "summary", "messages", "createdAt"]
    }
  },
  "firestore": {
    "/analyses/{analysisId}": {
      "schema": {
        "$ref": "#/entities/AnalysisResult"
      },
      "description": "Stores the analysis results for each user."
    }
  }
}
