rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /analyses/{document=**} {
      allow read, write: if true;
    }
    match /logins/{document=**} {
      allow read, write: if true;
    }
    match /test/{document=**} {
      allow read, write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
